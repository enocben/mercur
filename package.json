{
  "private": true,
  "name": "mercur",
  "version": "1.0.0",
  "devDependencies": {
    "turbo": "^2.3.3",
    "@types/bun": "latest"
  },
  "bin": {
    "mercur-exec": "./index.js"
  },
  "packageManager": "bun@1.2.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/modules/*"
  ],
  "scripts": {
    "mercur-exec": "turbo run dev",
    "dev": "turbo run dev",
    "start": "cd apps/backend && medusa start --types=false",
    "build": "turbo run build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "codegen": "cd .",
    "generate:oas": "turbo run generate:oas"
  },
  "module": "index.js",
  "type": "module",
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "zod": "^3.23.0"
  },
  "resolutions": {
    "zod": "^3.23.0"
  }
}
